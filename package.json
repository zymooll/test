{
  "name": "melodix",
  "version": "1.0.0",
  "description": "A modern Electron-based music player with immersive playback experience",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "keywords": ["music", "player", "electron", "audio"],
  "author": {
    "name": "Melodix",
    "email": "melodix@example.com"
  },
  "license": "MIT",
  "dependencies": {
    "music-metadata": "^10.6.1"
  },
  "devDependencies": {
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.melodix.player",
    "productName": "Melodix",
    "asar": true,
    "extraResources": [
      { "from": "preload.js", "to": "preload.js" }
    ],
    "files": [
      "main.js",
      "src/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.music"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icon.png",
      "category": "Audio"
    }
  }
}
